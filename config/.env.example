# ParseHub Kubernetes Configuration
# Copy this template and update with your actual values

# =============================================
# GENERAL
# =============================================
ENVIRONMENT=production
NAMESPACE=parsehub
DOMAIN=yourdomain.com

# =============================================
# CONTAINER REGISTRY
# =============================================
# For local Kind cluster: localhost:5000/parsehub-*
# For AWS ECR: YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/parsehub-*
# For Docker Hub: docker.io/YOUR_USERNAME/parsehub-*
REGISTRY=your-registry
BACKEND_IMAGE=$REGISTRY/parsehub-backend
FRONTEND_IMAGE=$REGISTRY/parsehub-frontend
IMAGE_TAG=latest

# =============================================
# SNOWFLAKE DATABASE
# =============================================
SNOWFLAKE_ACCOUNT=XXXXXXXXX-XX99999
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=YOUR_DB
SNOWFLAKE_SCHEMA=YOUR_SCHEMA

# =============================================
# API CONFIGURATION
# =============================================
PARSEHUB_API_KEY=your_api_key

# =============================================
# FRONTEND URLs
# =============================================
NEXT_PUBLIC_API_URL=https://api.$DOMAIN
FRONTEND_URL=https://app.$DOMAIN

# =============================================
# BACKEND CONFIGURATION
# =============================================
FLASK_ENV=production
LOG_LEVEL=info
ALLOWED_ORIGINS=https://app.$DOMAIN,https://$DOMAIN

# =============================================
# KUBERNETES REPLICAS
# =============================================
BACKEND_REPLICAS=3
FRONTEND_REPLICAS=2

# =============================================
# RESOURCE LIMITS (local testing)
# =============================================
BACKEND_REQUEST_MEMORY=256Mi
BACKEND_REQUEST_CPU=250m
BACKEND_LIMIT_MEMORY=512Mi
BACKEND_LIMIT_CPU=500m

FRONTEND_REQUEST_MEMORY=128Mi
FRONTEND_REQUEST_CPU=100m
FRONTEND_LIMIT_MEMORY=256Mi
FRONTEND_LIMIT_CPU=300m

# =============================================
# EMAIL NOTIFICATIONS
# =============================================
# SMTP Settings for error alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=parsehub-alerts@yourdomain.com
SMTP_USE_TLS=true

# Email recipient for failure alerts
ERROR_NOTIFICATION_EMAIL=admin@yourdomain.com

# Note: For Gmail:
# - Use an App Password (not your regular Gmail password)
# - Enable 2-Step Verification first: https://myaccount.google.com/security
# - Generate app password at: https://myaccount.google.com/apppasswords

