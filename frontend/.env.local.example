# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control!

# ─── ParseHub API (direct API access for run/analytics routes) ───────────────
PARSEHUB_API_KEY=
PARSEHUB_BASE_URL=https://www.parsehub.com/api/v2

# ─── Backend Proxy URL (SERVER-SIDE ONLY — never expose to browser) ──────────
BACKEND_API_URL=
# Production frontend service → Variables:
# BACKEND_API_URL=
# ─── Optional: Internal API key for Flask backend ────────────────────────────
BACKEND_API_KEY=
# ─── DEPRECATED — no longer needed (browser now calls same-origin /api/*) ────
# NEXT_PUBLIC_API_BASE_URL= 
